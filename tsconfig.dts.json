{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "newLine": "LF",
    "target": "ES2022",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "strictNullChecks": false,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@mysten/sui/client": ["./src/shim/mysten-sui-client.ts"]
    },
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
